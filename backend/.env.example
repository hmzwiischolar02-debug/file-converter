# Copy this file to .env and fill in your values
# Backend environment variables

# Max upload size in bytes (default: 10MB)
MAX_FILE_SIZE=10485760

# Auto-delete uploaded files after this many seconds (default: 1 hour)
FILE_TTL_SECONDS=3600

# Allowed frontend origin for CORS (use * for development only)
CORS_ORIGIN=*

# Optional: AWS S3 for scalable file storage
# AWS_ACCESS_KEY=your_access_key
# AWS_SECRET_KEY=your_secret_key
# AWS_BUCKET=fileconvert-temp
# AWS_REGION=us-east-1

# Optional: Redis for caching & rate limiting
# REDIS_URL=redis://localhost:6379
